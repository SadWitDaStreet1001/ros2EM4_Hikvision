<launch>
  <arg name="rtsp_url" default="rtsp://admin:hyzx_hyzx@192.168.1.64:554/Streaming/Channels/101"/>
  <arg name="image_topic" default="/hikvision/image_raw"/>
  <arg name="frame_id" default="hikvision_camera"/>
  <arg name="encoding" default="bgr8"/>
  <arg name="capture_backend" default="ffmpeg"/>
  <arg name="ffmpeg_capture_options" default="rtsp_transport;tcp|fflags;nobuffer|flags;low_delay|max_delay;0|reorder_queue_size;0|stimeout;5000000"/>
  <arg name="target_fps" default="0.0"/>
  <arg name="show_local" default="false"/>
  <arg name="publisher_queue_size" default="1"/>
  <arg name="reconnect_delay" default="2.0"/>
  <arg name="read_fail_limit" default="25"/>

  <node pkg="collector" type="hikvision_node.py" name="hikvision" output="screen">
    <param name="rtsp_url" value="$(arg rtsp_url)"/>
    <param name="image_topic" value="$(arg image_topic)"/>
    <param name="frame_id" value="$(arg frame_id)"/>
    <param name="encoding" value="$(arg encoding)"/>
    <param name="capture_backend" value="$(arg capture_backend)"/>
    <param name="ffmpeg_capture_options" value="$(arg ffmpeg_capture_options)"/>
    <param name="target_fps" value="$(arg target_fps)"/>
    <param name="show_local" value="$(arg show_local)"/>
    <param name="publisher_queue_size" value="$(arg publisher_queue_size)"/>
    <param name="reconnect_delay" value="$(arg reconnect_delay)"/>
    <param name="read_fail_limit" value="$(arg read_fail_limit)"/>
  </node>
</launch>
